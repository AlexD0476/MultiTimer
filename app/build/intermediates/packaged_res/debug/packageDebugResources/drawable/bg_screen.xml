<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/nightBackgroundAlt"
                android:startColor="@color/nightBackground" />
        </shape>
    </item>
    <item android:gravity="top|end" android:right="-80dp" android:top="-40dp">
        <shape android:shape="oval">
            <size android:width="260dp" android:height="260dp" />
            <solid android:color="@color/scrimSoft" />
        </shape>
    </item>
</layer-list>