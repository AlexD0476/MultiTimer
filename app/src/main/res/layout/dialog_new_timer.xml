<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MultiTimer.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_timer_name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialogInputTimerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionNext"
            android:inputType="textCapWords"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textMuted" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MultiTimer.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_minutes">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialogInputMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MultiTimer.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_seconds">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialogInputSeconds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="30"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textMuted" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogPresetThirtySeconds"
            style="@style/Widget.MultiTimer.SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="30s" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogPresetTwoMinutes"
            style="@style/Widget.MultiTimer.SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2m" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogPresetFiveMinutes"
            style="@style/Widget.MultiTimer.SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="5m" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/label_alarm_frequency"
        android:textColor="@color/textSecondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <RadioGroup
            android:id="@+id/dialogAlarmFrequencyGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <RadioButton
                android:id="@+id/dialogAlarmFrequencySingle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/alarm_frequency_none"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/dialogAlarmFrequencyEverySecond"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/alarm_frequency_1s"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/dialogAlarmFrequencyEveryThreeSeconds"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/alarm_frequency_3s"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/dialogAlarmFrequencyEveryFiveSeconds"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/alarm_frequency_5s"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:gravity="center" />
        </RadioGroup>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_alarm_volume"
        android:textColor="@color/textSecondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.slider.Slider
            android:id="@+id/dialogAlarmVolumeSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0"
            android:valueTo="100"
            android:value="100"
            android:stepSize="5" />

        <TextView
            android:id="@+id/dialogAlarmVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="100%"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:minWidth="40dp" />
    </LinearLayout>

</LinearLayout>